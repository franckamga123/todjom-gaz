# ==========================================
# TODJOM GAZ - CONFIGURATION TEMPLATE
# ==========================================

# --- SERVEUR ---
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# --- BASE DE DONNÉES (MySQL) ---
DB_HOST=127.0.0.1
DB_USER=root
DB_PASS=
DB_NAME=todjom_gaz
DB_DIALECT=mysql

# --- SÉCURITÉ (JWT) ---
JWT_SECRET=remplacer_par_une_cle_securisee_64_chars
JWT_EXPIRES_IN=7d

# --- NOTIFICATIONS WHATSAPP (TWILIO) ---
# Obtenez ces clés sur https://www.twilio.com/console
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# --- PAIEMENTS (MY NITA / AMANA) ---
# Mode: sandbox ou production
PAYMENT_MODE=sandbox
PAYMENT_API_KEY=your_payment_api_key_here

# --- SMS (OPTIONNAL) ---
SMS_GATEWAY_API_KEY=your_sms_gateway_key

# --- LOGS ---
# Niveau de log: info, error, debug
LOG_LEVEL=info
